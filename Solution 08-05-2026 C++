#include <vector>
#include <queue>

using namespace std;

// Using global arrays ensures the Sieve is only computed once across all test cases
const int MAX_VAL = 1000005;
int spf[MAX_VAL];
int prime_id[MAX_VAL];
int num_primes = 0;
bool initialized = false;

void initSieve() {
    if (initialized) return;
    
    for (int i = 2; i < MAX_VAL; i++) {
        spf[i] = i;
        prime_id[i] = -1;
    }
    
    // Smallest Prime Factor (SPF)
    for (int i = 2; i * i < MAX_VAL; i++) {
        if (spf[i] == i) {
            for (int j = i * i; j < MAX_VAL; j += i) {
                if (spf[j] == j) spf[j] = i;
            }
        }
    }
    
    // Map each actual prime to a compact 0-indexed ID to save memory
    for (int i = 2; i < MAX_VAL; i++) {
        if (spf[i] == i) {
            prime_id[i] = num_primes++;
        }
    }
    initialized = true;
}

class Solution {
public:
    int minJumps(vector<int>& nums) {
        initSieve();
        
        int n = nums.size();
        if (n <= 1) return 0;
        
        // Maps prime IDs to all indices in `nums` divisible by that prime
        vector<vector<int>> prime_to_indices(num_primes);
        
        for (int i = 0; i < n; i++) {
            int x = nums[i];
            while (x > 1) {
                int p = spf[x];
                prime_to_indices[prime_id[p]].push_back(i);
                
                // Remove all factors of p to get distinct primes
                while (x % p == 0) x /= p;
            }
        }
        
        vector<int> dist(n, -1);
        vector<bool> visited_primes(num_primes, false);
        queue<int> q;
        
        q.push(0);
        dist[0] = 0;
        
        // Start BFS
        while (!q.empty()) {
            int u = q.front();
            q.pop();
            
            // If we reached the end
            if (u == n - 1) return dist[u];
            
            // 1. Adjacent Step: Right
            if (u + 1 < n && dist[u + 1] == -1) {
                dist[u + 1] = dist[u] + 1;
                q.push(u + 1);
            }
            
            // 2. Adjacent Step: Left
            if (u - 1 >= 0 && dist[u - 1] == -1) {
                dist[u - 1] = dist[u] + 1;
                q.push(u - 1);
            }
            
            // 3. Prime Teleportation
            int val = nums[u];
            
            // Check if the current number is strictly a prime number itself
            if (val >= 2 && spf[val] == val) { 
                int pid = prime_id[val];
                
                // Only trigger teleportation if we haven't used this prime yet
                if (!visited_primes[pid]) {
                    visited_primes[pid] = true;
                    for (int v : prime_to_indices[pid]) {
                        if (dist[v] == -1) {
                            dist[v] = dist[u] + 1;
                            q.push(v);
                        }
                    }
                }
            }
        }
        
        return dist[n - 1]; 
    }
};
