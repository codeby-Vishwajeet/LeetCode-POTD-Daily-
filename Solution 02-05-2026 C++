class Solution {
public:
    int rotatedDigits(int n) {
        int goodCount = 0;
        
        for (int i = 1; i <= n; ++i) {
            int num = i;
            bool hasRotatedDiff = false;
            bool isValid = true;
            
            while (num > 0) {
                int digit = num % 10;
                
                // If the number contains 3, 4, or 7, it's completely invalid
                if (digit == 3 || digit == 4 || digit == 7) {
                    isValid = false;
                    break;
                }
                
                // If it contains 2, 5, 6, or 9, it will become a different valid number
                if (digit == 2 || digit == 5 || digit == 6 || digit == 9) {
                    hasRotatedDiff = true;
                }
                
                // Digits 0, 1, and 8 are valid but don't change the number, 
                // so we don't need to flag them specifically.
                
                num /= 10;
            }
            
            // A number is good if it has no invalid digits AND at least one digit that changes
            if (isValid && hasRotatedDiff) {
                goodCount++;
            }
        }
        
        return goodCount;
    }
};
